{
  "name": "wavesafe-deck-plugin",
  "version": "0.2.0",
  "description": "WaveSafe — fully offline local-library music player for the Steam Deck, controlled in-game from the Quick Access Menu (Decky plugin).",
  "license": "MIT",
  "author": "Ember Gábor",
  "type": "module",
  "scripts": {
    "build": "shx rm -rf dist && rollup -c",
    "watch": "rollup -c -w",
    "test:ts": "node --test \"src/**/*.test.ts\"",
    "test:py": "python3 -m unittest discover -s tests -p 'test_*.py'",
    "test:func": "python3 -m unittest discover -s tests_functional -p 'test_*.py'"
  },
  "devDependencies": {
    "@decky/api": "^1.1.0",
    "@decky/rollup": "^1.0.0",
    "@decky/ui": "^4.7.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.0.0",
    "rollup": "^4.0.0",
    "shx": "^0.3.4",
    "typescript": "^5.5.0"
  },
  "decky": {
    "//": "Files copied into the packaged plugin alongside dist/index.js so the Python backend finds them at runtime (relative to DECKY_PLUGIN_DIR).",
    "bundle": [
      "main.py",
      "mpd_client.py",
      "daemon/mpd.conf.tmpl",
      "bin/mpd"
    ]
  }
}
